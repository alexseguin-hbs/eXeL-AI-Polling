{
  "name": "exel-ai-polling",
  "compatibility_date": "2026-02-14",
  "assets": {
    "directory": "./out",
    "not_found_handling": "single-page-application"
  },
  // KV binding for cross-device session + response storage.
  // Manual step: Create KV namespace in CF Dashboard → copy ID here.
  // Also bind in CF Pages → Settings → Functions → KV namespace bindings → Variable: RESPONSES
  "kv_namespaces": [{ "binding": "RESPONSES", "id": "<YOUR_KV_NAMESPACE_ID>" }]
}
