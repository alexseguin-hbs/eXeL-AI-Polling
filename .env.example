# ===========================================
# SoI Polling Tool - Environment Variables
# ===========================================
# Copy this file to .env and fill in values

# --- Database ---
DATABASE_URL=postgresql+asyncpg://polling:polling@localhost:5432/polling_db
MONGODB_URI=mongodb://polling:polling@localhost:27017/polling_raw?authSource=admin
REDIS_URL=redis://localhost:6379/0

# --- Auth0 ---
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_API_AUDIENCE=https://api.exel-polling.com
AUTH0_CLIENT_ID=your-client-id
AUTH0_CLIENT_SECRET=your-client-secret

# --- AI Providers (launch: OpenAI, Grok/xAI, Gemini/Google, Claude/Anthropic) ---
OPENAI_API_KEY=sk-...
XAI_API_KEY=xai-...
GEMINI_API_KEY=...
ANTHROPIC_API_KEY=sk-ant-...
DEFAULT_AI_PROVIDER=openai  # openai | grok | gemini | claude

# --- Security ---
ENCRYPTION_KEY=
SESSION_SECRET=

# --- App ---
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
